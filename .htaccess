ErrorDocument 404 /miniwebsite/404.php

RewriteEngine On

# If the requested file or directory exists, serve it directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Single path segment (e.g. /akhitest3) -> n.php?n=akhitest3 (clean URL)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^/\.]+)$ n.php?n=$1 [L,QSA]

# Otherwise, let PHP/front controller or 404 handle it normally

